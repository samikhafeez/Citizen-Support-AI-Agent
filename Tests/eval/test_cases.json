{
  "metadata": {
    "description": "Bradford Council Chatbot test cases for automated evaluation",
    "version": "1.0",
    "categories": ["routing", "quality", "regression", "safeguarding", "resilience"]
  },
  "test_cases": [

    // ── Routing ───────────────────────────────────────────────────────────────
    {
      "id": "RT-001",
      "category": "routing",
      "input": "How do I pay my council tax?",
      "expected_service": "Council Tax",
      "banned_phrases": ["context does not", "I am not able"],
      "required_phrases": [],
      "notes": "Core council tax payment query"
    },
    {
      "id": "RT-002",
      "category": "routing",
      "input": "When is my bin collection?",
      "expected_service": "Waste & Bins",
