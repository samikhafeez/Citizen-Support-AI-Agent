    },

    // ── Regression ────────────────────────────────────────────────────────────
    {
      "id": "RG-001",
      "category": "regression",
      "input": "hi",
      "context_service": "Council Tax",
      "expected_service": "Unknown",
      "banned_phrases": ["council tax", "payment", "direct debit"],
      "required_phrases": [],
      "notes": "R1: greeting after Council Tax must not inherit context"
    },
    {
      "id": "RG-002",
      "category": "regression",
      "input": "I am at risk of eviction",
      "expected_service": "Housing",
      "banned_phrases": ["Hello!", "Hi!"],
      "required_phrases": [],
      "notes": "R9: 'I am at risk of...' must not trigger name-greeting guard"
    },
    {
      "id": "RG-003",
      "category": "regression",
      "input": "How do I apply for council tax support?",
      "expected_service": "Benefits & Support",
      "banned_phrases": ["student", "full-time student"],
      "required_phrases": [],
      "notes": "R5: council tax support ≠ student discount"
    },
    {
      "id": "RG-004",
      "category": "regression",
      "input": "How can I contact the council?",
      "expected_service": "Contact Us",
      "banned_phrases": ["I didn't quite catch", "could you tell me more"],
      "required_phrases": ["01274 431000"],
      "notes": "R8: must return contact info, not clarification"
    },

    // ── Quality ───────────────────────────────────────────────────────────────
    {
      "id": "QA-001",
      "category": "quality",
      "input": "How do I pay my council tax?",
      "expected_service": "Council Tax",
      "banned_phrases": [
        "context does not provide",
        "context does not specify",
        "the context does not",
        "based on the context",
        "I am not able to find",
        "I cannot find"
      ],
      "required_phrases": [],
      "notes": "Must never expose internal context references"
    },
    {
      "id": "QA-002",
      "category": "quality",
      "input": "Am I eligible for a blue badge?",
      "expected_service": "Benefits & Support",
      "banned_phrases": [
        "context does not",
        "I am not able",
        "As an AI language model"
      ],
      "required_phrases": [],
      "notes": "No AI/context leakage in benefits reply"
    },
    {
      "id": "QA-003",
      "category": "quality",
      "input": "hello",
      "expected_service": "Unknown",
      "min_reply_length": 5,
      "max_reply_length": 200,
      "notes": "Greeting reply should be short but not empty"
    }
